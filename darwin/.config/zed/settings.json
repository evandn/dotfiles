{
  "theme": "One Dark",
  "buffer_font_size": 14,
  "show_whitespaces": "boundary",
  "soft_wrap": "editor_width",
  "colorize_brackets": true,
  "indent_guides": {
    "coloring": "indent_aware",
    "background_coloring": "indent_aware"
  },
  "preview_tabs": {
    "enabled": false
  },
  "line_ending": "enforce_lf",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "ssh_connections": [
    {
      "host": "orb"
    }
  ],
  "languages": {
    "Shell Script": {
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": ["--filename", "{buffer_path}"]
        }
      }
    }
  }
}
